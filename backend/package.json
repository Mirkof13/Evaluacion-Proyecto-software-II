{
  "name": "bancosol-backend",
  "version": "1.0.0",
  "description": "BancoSol - Sistema de Gestión de Cartera de Créditos",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watch",
    "db:migrate": "sequelize-cli db:migrate",
    "db:seed": "sequelize-cli db:seed:all",
    "db:reset": "sequelize-cli db:drop && sequelize-cli db:create && sequelize-cli db:migrate && sequelize-cli db:seed:all",
    "seed:real": "node database/seed_real.js",
    "kill-port": "powershell -Command \"$p = Get-NetTCPConnection -LocalPort 5000 -ErrorAction SilentlyContinue; if($p) { Stop-Process -Id $p.OwningProcess -Force -ErrorAction SilentlyContinue }\"",
    "prepare": "husky install"
  },
  "keywords": [
    "bancario",
    "creditos",
    "ciberseguridad",
    "iso27001"
  ],
  "author": "Ingeniería Software II",
  "license": "MIT",
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^6.10.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "pg": "^8.11.3",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.35.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "eslint": "^10.2.1",
    "eslint-plugin-no-unsanitized": "^4.1.5",
    "eslint-plugin-security": "^4.0.0",
    "husky": "^8.0.0",
    "jest": "^29.7.0",
    "lint-staged": "^16.4.0",
    "nodemon": "^3.0.1",
    "prettier": "^3.8.3",
    "sequelize-cli": "^6.6.2",
    "supertest": "^6.3.3"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}

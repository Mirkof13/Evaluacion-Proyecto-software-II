# ============================================
# BANCOSOL - Variables de Entorno
# ============================================
# Copiar a .env y ajustar valores

# Entorno
NODE_ENV=development

# Servidor
PORT=5000
HOST=localhost

# Base de datos PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bancosol_db
DB_USER=postgres
DB_PASSWORD=tu_password_segura_aqui

# JWT (Cambiar en producción - mínimo 256 bits)
JWT_SECRET=bancosol_super_secret_key_cambiar_en_produccion_256bits_minimo
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=bancosol_refresh_secret_separado
JWT_REFRESH_EXPIRES_IN=7d

# Bcrypt (salt rounds - recomendado: 12)
BCRYPT_ROUNDS=12

# CORS (frontend URL)
CORS_ORIGIN=http://localhost:3000

# Límites de rate limiting
RATE_LIMIT_WINDOW_MS=15 * 60 * 1000
RATE_LIMIT_MAX_REQUESTS=100

# Auditoría (logs en tabla)
AUDIT_LOG_ENABLED=true
AUDIT_LOG_ASYNC=true

# Logging
LOG_LEVEL=debug
